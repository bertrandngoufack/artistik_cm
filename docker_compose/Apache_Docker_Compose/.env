# Artistik CM — WordPress dans web/artistik_cm
COMPOSE_PROJECT_NAME=artistik-php
WEB_IMAGE=artistik-php-web:local

# Racine Apache = ./web pour URL http://localhost:PORT/artistik_cm/
WEB_MOUNT=./web
# URL complète du site WordPress (sous-dossier). Vide si WP à la racine du montage.
WP_PUBLIC_URL=http://localhost:8080/artistik_cm

HTTP_PORT=8080
APACHE_DOCUMENT_ROOT=/var/www/html
APACHE_SERVER_ADMIN=info@artistik.cm
APACHE_ERROR_DOCUMENT_404=/index.php
APACHE_VHOST_TEMPLATE=./apache/vhost.conf.template

PHP_BASE_IMAGE=php:8.4-apache-bookworm
INSTALL_WPCLI=1

# Pas d’index PHP auto généré (WordPress fournit index.php)
CREATE_DEFAULT_INDEX=0
COMPOSER_INSTALL_ON_START=0

DB_HOST=mariadb
DB_NAME=artistik_cm_db
DB_USER=app_user
DB_PASSWORD=Bateau123
DB_ROOT_PASSWORD=Bateau123
# 1 = au démarrage du conteneur web, créer DB_NAME et droits (volume MariaDB déjà existant inclus)
ENSURE_MYSQL_DATABASE=1
DB_PORT_MAPPING=3307

MARIADB_IMAGE=mariadb:11.4
MARIADB_AUTO_UPGRADE=1
MARIADB_DATA_DIR=./data/mariadb

PMA_PORT=8081
# Sonde HTTP du conteneur web (sous-dossier WordPress)
HEALTHCHECK_PATH=/artistik_cm/

RESTART_POLICY=unless-stopped
ENV_FILE=.env
