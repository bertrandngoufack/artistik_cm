# Docker / local : WP_PUBLIC_URL = http://localhost:PORT/artistik_cm/ (.env APACHE_DOCUMENT_ROOT = ./web)
# Les URLs TranslatePress (/en/, …) DOIVENT être réécrites vers artistik_cm/index.php — pas vers /index.php (page statut Docker).
#
# Production à la racine du domaine : utiliser .htaccess.production-root.example à la place.

# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteBase /artistik_cm/
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /artistik_cm/index.php [L]
</IfModule>
# END WordPress
