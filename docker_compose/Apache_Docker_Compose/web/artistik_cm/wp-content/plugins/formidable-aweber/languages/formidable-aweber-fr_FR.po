#: views/settings/form.php:18
msgid "Authorization ID"
msgstr "ID d’autorisation"

#: views/settings/form.php:28
msgid "To setup AWeber:"
msgstr "Pour configurer AWeber :"

#: views/settings/form.php:30
msgid "Before you can use AWeber with your forms, you first need to authorize it to access your AWeber account."
msgstr "Avant de pouvoir utiliser AWeber avec vos formulaires, vous devez d’abord l’autoriser à accéder à votre compte AWeber."

#: views/settings/form.php:30
msgid "Click here to get your AWeber authorization ID."
msgstr "Cliquez ici pour obtenir votre ID d’autorisation AWeber."

#: views/settings/form.php:31
msgid "After you login to AWeber, you will be given an authorization ID. Copy it and paste it below."
msgstr "Une fois la connexion à AWeber établie, vous recevrez un ID d’autorisation. Copiez-le et collez-le ci-dessous."

#: views/settings/form.php:32
msgid "Click Update. If you see a success message you are ready to setup your forms to create AWeber contacts."
msgstr "Cliquez sur Mettre à jour. Si vous voyez un message de réussite, vous êtes prêt·e à configurer vos formulaires pour créer des contacts AWeber."

