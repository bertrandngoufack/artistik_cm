#: helpers/FrmStrpApiHelper.php:676
msgid "The card number is incorrect."
msgstr "Il numero della carta non è corretto."

#: helpers/FrmStrpApiHelper.php:677
msgid "The card number is not a valid credit card number."
msgstr "Il numero della carta non è un numero di carta di credito valido."

#: helpers/FrmStrpApiHelper.php:678
msgid "The card's expiration month is invalid."
msgstr "Il mese di scadenza della carta non è valido."

#: helpers/FrmStrpApiHelper.php:679
msgid "The card's expiration year is invalid."
msgstr "L'anno di scadenza della carta non è valido."

#: helpers/FrmStrpApiHelper.php:680
msgid "The card's security code is invalid."
msgstr "Il codice di sicurezza della carta non è valido."

#: helpers/FrmStrpApiHelper.php:681
msgid "The card has expired."
msgstr "La carta è scaduta."

#: helpers/FrmStrpApiHelper.php:682
msgid "The card's security code is incorrect."
msgstr "Il codice di sicurezza della carta non è corretto."

#: helpers/FrmStrpApiHelper.php:683
msgid "The card's zip code failed validation."
msgstr "Il codice postale della carta non è stato convalidato."

#: helpers/FrmStrpApiHelper.php:684
msgid "The card was declined."
msgstr "La carta è stata rifiutata."

#: helpers/FrmStrpApiHelper.php:685
msgid "There is no card on a customer that is being charged."
msgstr "Non c'è nessuna carta di un cliente che è stata caricata."

#: helpers/FrmStrpApiHelper.php:686
msgid "An error occurred while processing the card."
msgstr "Si è verificato un errore durante l'elaborazione della carta."

#: helpers/FrmStrpApiHelper.php:687
msgid "An error occurred due to requests hitting the API too quickly. Please let us know if you're consistently running into this error."
msgstr "Si è verificato un errore a causa di richieste troppo rapide all'API. Facci sapere se riscontri costantemente questo errore."

#: helpers/FrmStrpApiHelper.php:688
msgid "The card's swipe data is invalid."
msgstr "I dati di prelievo della carta non sono validi."

#: helpers/FrmStrpApiHelper.php:689
msgid "Too many requests hit the API too quickly."
msgstr "Troppe richieste arrivano all'API troppo velocemente."

#: helpers/FrmStrpApiHelper.php:690
msgid "Invalid request errors arise when your request has invalid parameters."
msgstr "Gli errori di richiesta non valida si verificano quando la richiesta ha parametri non validi."

#: helpers/FrmStrpApiHelper.php:691
msgid "Failed to properly authenticate in the request."
msgstr "Non è riuscita l'autenticazione corretta nella richiesta."

#: helpers/FrmStrpApiHelper.php:692
msgid "Failed to connect to Stripe's API. This usually means you have an issue with TLS 1.2 on your server."
msgstr "Impossibile connettersi all'API di Stripe. Questo di solito significa che c'è un problema con TLS 1.2 sul tuo server."

#: helpers/FrmStrpConnectHelper.php:782
msgid "Unable to delete card"
msgstr "Impossibile cancellare la carta"

