msgid "Add to HubSpot"
msgstr "Adicionar ao HubSpot"

#: models/FrmHubSpotAPI.php:114
msgid "Please enter your HubSpot Private App Access Token."
msgstr "Insira seu token de acesso ao aplicativo privado HubSpot."

#. translators: %1$s the error message that was returned
#: models/FrmHubSpotAPI.php:135
#: models/FrmHubSpotSettings.php:124
msgid "Invalid HubSpot Private App Access Token."
msgstr "Token de acesso ao aplicativo privado HubSpot inválido."

#: models/FrmHubSpotAPI.php:163
msgid "Your private access token could not be connected. Please check if you have valid PAT or you have an active version of cURL installed on your server."
msgstr "Não foi possível conectar seu token de acesso privado. Verifique se você tem um PAT válido ou uma versão ativa do cURL instalada em seu servidor."

#: models/FrmHubSpotAPI.php:338
msgid "Please check you have an active version of cURL installed on your server."
msgstr "Verifique se você tem uma versão ativa do cURL instalada em seu servidor."

#: models/FrmHubSpotAPI.php:505
msgid "No HubSpot lists found."
msgstr "Nenhuma lista HubSpot encontrada."

#: models/FrmHubSpotAPI.php:537
msgid "HubSpot:"
msgstr "HubSpot:"

#: models/FrmHubSpotAPI.php:569
msgid "You had an HTTP connection error"
msgstr "Você teve um erro de conexão HTTP"

