msgstr "Strategy11"

#. translators: %1$s: Minimum version HubSpot needs to work
#: controllers/FrmHubSpotAppController.php:25
msgid "You are running an outdated version of Formidable. This plugin needs Formidable v%1$s+ to work correctly."
msgstr "Stai usando una versione non aggiornata di Formidable. Questo plugin ha bisogno di Formidable v%1$s o successiva per funzionare correttamente."

#: controllers/FrmHubSpotAppController.php:255
#: models/FrmHubSpotAction.php:16
#: models/FrmHubSpotAction.php:130
msgid "HubSpot"
msgstr "HubSpot"

#: controllers/FrmHubSpotHooksController.php:113
msgid "Formidable HubSpot requires an active version of Formidable Pro."
msgstr "Formidable HubSpot richiede una versione attiva di Formidable Pro."

#: formidable-hubspot.php:68
msgid "Formidable HubSpot requires Formidable Forms to be installed."
msgstr "Formidable HubSpot richiede l'installazione di Formidable Forms."

#: formidable-hubspot.php:70
msgid "Install Formidable Forms"
msgstr "Installa Formidable Forms"

#: helpers/FrmHubSpotEncryptionHelper.php:65
msgid "Oops, Something is wrong with your openssl extension please contact your host provider."
msgstr "Ops, c'è qualcosa che non va con la tua estensione openssl. Contatta il tuo host."

#: helpers/FrmHubSpotEncryptionHelper.php:92
msgid "Oops, It seems your WordPress salt key has been changed or unreadable."
msgstr "Ops, sembra che la chiave salt di WordPress sia stata modificata o sia illeggibile."

#: models/FrmHubSpotAction.php:13
msgid "Add to HubSpot"
msgstr "Aggiungi a HubSpot"

#: models/FrmHubSpotAPI.php:114
msgid "Please enter your HubSpot Private App Access Token."
msgstr "Inserisci il tuo token di accesso all'app privata di HubSpot."

#. translators: %1$s the error message that was returned
#: models/FrmHubSpotAPI.php:135
#: models/FrmHubSpotSettings.php:124
msgid "Invalid HubSpot Private App Access Token."
msgstr "Token di accesso all'app privata di HubSpot non valido."

#: models/FrmHubSpotAPI.php:163
msgid "Your private access token could not be connected. Please check if you have valid PAT or you have an active version of cURL installed on your server."
msgstr "Non è stato possibile connettere il tuo token di accesso privato. Verifica di avere un PAT valido o di avere una versione attiva di cURL installata sul tuo server."

#: models/FrmHubSpotAPI.php:338
msgid "Please check you have an active version of cURL installed on your server."
msgstr "Verifica di avere una versione attiva di cURL installata sul tuo server."

#: models/FrmHubSpotAPI.php:505
msgid "No HubSpot lists found."
msgstr "Non sono state trovate liste HubSpot."

#: models/FrmHubSpotAPI.php:537
msgid "HubSpot:"
msgstr "HubSpot:"

#: models/FrmHubSpotAPI.php:569
msgid "You had an HTTP connection error"
msgstr "Si è verificato un errore di connessione HTTP"

#: models/FrmHubSpotOAuth.php:66
msgid "Invalid task for ajax endpoint"
msgstr "Attività non valida per l'endpoint ajax"

#. translators: %1$s: the fetched URL, %2$s the error message that was returned
#: models/FrmHubSpotOAuth.php:103
msgid "Failed to fetch: %1$s (%2$s)"
msgstr "Impossibile recuperare: %1$s (%2$s)"

#: models/FrmHubSpotOAuth.php:110
msgid "There is an issue with your access token. Please try to reauthorize the HubSpot API from the Global settings."
msgstr "Si è verificato un problema con il tuo token di accesso. Prova a riautorizzare l'API di HubSpot dalle impostazioni globali."

#: models/FrmHubSpotOAuth.php:143
msgid "The saved code is missing an expiration. Please deauthorize and then authorize again."
msgstr "Al codice salvato manca la scadenza. Disautorizza e autorizza di nuovo."

#: models/FrmHubSpotOAuth.php:177
msgid "Your API has been disconnected."
msgstr "Il tuo API è stato disconnesso."

#. translators: %1$s: the fetched URL, %2$s the error message that was returned
#: models/FrmHubSpotOAuth.php:186
msgid "Your API has been disconnected from HubSpot and there is no further action needed however following issue has been occurred in disconnection process: %1$s (%2$s)"
msgstr "La tua API è stata scollegata da HubSpot e non sono necessarie ulteriori azioni. Durante il processo di disconnessione, però, si è verificato il seguente problema: %1$s (%2$s)"

#: models/FrmHubSpotOAuth.php:189
msgid "HubSpot API has been successfully disconnected"
msgstr "L'API di HubSpot è stata scollegata con successo"

#: models/FrmHubSpotRemoteRequest.php:197
msgid "Unknown error"
msgstr "Errore sconosciuto"

#. translators: %1$s: response message
#: models/FrmHubSpotRemoteRequest.php:200
msgid "Failed to fetch the contents: %1$s as it returned HTTP status 500."
msgstr "Non è stato possibile recuperare il contenuto %1$s poiché ha restituito lo stato HTTP 500."

#. translators: %1$s: url, %2$s: status code
#: models/FrmHubSpotRemoteRequest.php:206
msgid "Failed to fetch the contents from the URL %1$s as it returned HTTP status %2$s."
msgstr "Non è stato possibile recuperare il contenuto dell'URL %1$s poiché ha restituito lo stato HTTP %2$s."

