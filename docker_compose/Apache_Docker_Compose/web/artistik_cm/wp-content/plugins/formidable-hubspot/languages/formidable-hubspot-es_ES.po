msgstr "Tarea no válida para el punto final ajax"

#. translators: %1$s: the fetched URL, %2$s the error message that was returned
#: models/FrmHubSpotOAuth.php:103
msgid "Failed to fetch: %1$s (%2$s)"
msgstr "No se ha podido recuperar: %1$s (%2$s)"

#: models/FrmHubSpotOAuth.php:110
msgid "There is an issue with your access token. Please try to reauthorize the HubSpot API from the Global settings."
msgstr "Hay un problema con tu token de acceso. Intenta volver a autorizar la API de HubSpot desde los ajustes globales."

#: models/FrmHubSpotOAuth.php:143
msgid "The saved code is missing an expiration. Please deauthorize and then authorize again."
msgstr "Al código guardado le falta la fecha de caducidad. Por favor, desautorízalo y vuelve a autorizarlo."

#: models/FrmHubSpotOAuth.php:177
msgid "Your API has been disconnected."
msgstr "Se ha desconectado tu API."

#. translators: %1$s: the fetched URL, %2$s the error message that was returned
#: models/FrmHubSpotOAuth.php:186
msgid "Your API has been disconnected from HubSpot and there is no further action needed however following issue has been occurred in disconnection process: %1$s (%2$s)"
msgstr "Se ha desconectado tu API de HubSpot y no es necesario realizar ninguna otra acción, sin embargo, se ha producido el siguiente problema en el proceso de desconexión: %1$s (%2$s)"

#: models/FrmHubSpotOAuth.php:189
msgid "HubSpot API has been successfully disconnected"
msgstr "La API de HubSpot se ha desconectado correctamente"

