msgid "Please enter your HubSpot Private App Access Token."
msgstr "Introduce tu token de acceso a la aplicación privada de HubSpot."

#. translators: %1$s the error message that was returned
#: models/FrmHubSpotAPI.php:135
#: models/FrmHubSpotSettings.php:124
msgid "Invalid HubSpot Private App Access Token."
msgstr "Token de acceso a la aplicación privada de HubSpot no válido."

#: models/FrmHubSpotAPI.php:163
msgid "Your private access token could not be connected. Please check if you have valid PAT or you have an active version of cURL installed on your server."
msgstr "No se ha podido conectar tu token de acceso privado. Por favor, comprueba si tienes un PAT válido o si tienes una versión activa de cURL instalada en tu servidor."

#: models/FrmHubSpotAPI.php:338
msgid "Please check you have an active version of cURL installed on your server."
msgstr "Comprueba que tienes una versión activa de cURL instalada en tu servidor."

