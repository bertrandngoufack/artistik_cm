# Copier vers .env et adapter : cp .env.example .env
# Projet Docker Compose (préfixe conteneurs / réseau)
COMPOSE_PROJECT_NAME=artistik-php

# Image produite par le build du service web (tag local)
WEB_IMAGE=artistik-php-web:local

# --- Code applicatif (chemin hôte vers la racine Apache dans le conteneur)
# Exemple sous-dossier WordPress : WEB_MOUNT=./web + site en /nom_du_dossier/
WEB_MOUNT=./web
# URL publique du site si WordPress n’est pas à la racine du montage (sinon laisser vide)
# WP_PUBLIC_URL=http://localhost:8080/artistik_cm
WP_PUBLIC_URL=

# --- Apache
HTTP_PORT=8080
# Racine document dans le conteneur (ex. /var/www/html ou /var/www/html/public pour Laravel/Symfony)
APACHE_DOCUMENT_ROOT=/var/www/html
APACHE_SERVER_ADMIN=webmaster@localhost
APACHE_ERROR_DOCUMENT_404=/index.php
# Fichier gabarit vhost (relatif au répertoire du compose)
APACHE_VHOST_TEMPLATE=./apache/vhost.conf.template

# --- Image PHP (build)
PHP_BASE_IMAGE=php:8.4-apache-bookworm
INSTALL_WPCLI=1

# --- PHP (runtime → zz-runtime.ini)
PHP_MEMORY_LIMIT=256M
PHP_MAX_EXECUTION_TIME=300
PHP_MAX_INPUT_TIME=300
PHP_UPLOAD_MAX_SIZE=64M
PHP_POST_MAX_SIZE=64M
PHP_MAX_INPUT_VARS=3000
PHP_DATE_TIMEZONE=UTC
PHP_DISPLAY_ERRORS=On
PHP_ERROR_REPORTING=E_ALL
PHP_LOG_ERRORS=On
# OPcache
PHP_OPCACHE_MEMORY_CONSUMPTION=256
PHP_OPCACHE_INTERNED_STRINGS_BUFFER=16
PHP_OPCACHE_MAX_ACCELERATED_FILES=10000
PHP_OPCACHE_REVALIDATE_FREQ=2

# Fichier ini statique additionnel (optionnel, laissez tel quel si vous utilisez php.ini du dépôt)
PHP_CUSTOM_INI=./php.ini

# --- Base de données (service interne = nom du service compose)
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=app_database
DB_USER=app_user
DB_PASSWORD=change_me_in_prod
DB_ROOT_PASSWORD=change_root_in_prod
ENSURE_MYSQL_DATABASE=1

# Image MariaDB
MARIADB_IMAGE=mariadb:11.4
# 1 = exécute mariadb-upgrade au démarrage si le data dir vient d’une version antérieure (recommandé)
MARIADB_AUTO_UPGRADE=1

# Port MySQL exposé sur l’hôte (3306 souvent déjà pris)
DB_PORT_MAPPING=3307

# --- phpMyAdmin (profile: tools)
PMA_PORT=8081
PMA_IMAGE=phpmyadmin/phpmyadmin:latest

# --- Compose / exploitation
RESTART_POLICY=unless-stopped
NETWORK_DRIVER=bridge
ENV_FILE=.env
MARIADB_DATA_DIR=./data/mariadb

# Dépendances au démarrage du conteneur web
COMPOSER_INSTALL_ON_START=1
COMPOSER_INSTALL_DEV=0
CREATE_DEFAULT_INDEX=1

# Healthchecks (syntaxe durée Compose, ex. 30s, 1m)
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START_PERIOD=10s
DB_HEALTHCHECK_START_PERIOD=40s

# --- Santé du conteneur web
HEALTHCHECK_PATH=/
