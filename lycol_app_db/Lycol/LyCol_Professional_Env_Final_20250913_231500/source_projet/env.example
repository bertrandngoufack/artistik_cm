CI_ENVIRONMENT = production

app.baseURL = 'http://localhost:8080/'
app.indexPage = ''

# Database (MariaDB)
database.default.hostname = 100.69.65.33
database.default.port     = 13306
database.default.database = lycol
database.default.username = root
database.default.password = Bateau123
database.default.DBDriver = MySQLi
database.default.charset  = utf8mb4
database.default.DBDebug  = true

# Encryption
encryption.key = base64:CHANGE_ME_GENERATE_WITH_CI4

# Email (SMTP)
email.fromEmail = 'no-reply@school.local'
email.fromName  = 'LYCOL'
email.SMTPHost  = 'smtp.example.com'
email.SMTPUser  = 'user@example.com'
email.SMTPPass  = 'change_me'
email.SMTPPort  = 587
email.SMTPCrypto= 'tls'

# SMS / WhatsApp Providers
sms.defaultProvider = 'twilio'
sms.providers.twilio.sid     = ''
sms.providers.twilio.token   = ''
sms.providers.twilio.sender  = ''

whatsapp.provider = 'cloud-api'
whatsapp.token    = ''
whatsapp.phoneId  = ''

# API
api.enabled = true
api.version = 'v1'
api.rateLimit.perMinute = 60
api.cors.allowedOrigins = '*'

# Swagger / OpenAPI
docs.swagger.enabled = true

# License
license.secretSeed = 'CHANGE_ME_SECRET_SEED'
license.enforceTimeoutMinutesAfterExpiry = 20
